{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "outDir": ".test-dist",
    "jsx": "react-jsx"
  },
  "include": [
    "src/game.ts",
    "src/xiangqiEngine.ts",
    "src/jieqi.ts",
    "src/jieqiLobby.ts",
    "src/puzzle.ts",
    "src/puzzleLobby.ts",
    "src/xiangqiLobby.ts",
    "src/xiangqiCertification.ts",
    "src/xiangqiCoinArena.ts",
    "src/xiangqiMinuteArena.ts",
    "src/xiangqiRating.ts",
    "src/xiangqiHuashan.ts",
    "src/xiangqiFriendRoom.ts",
    "tests"
  ]
}
